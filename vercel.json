{
    "version":  2,
    "builds":  [
                   {
                       "src":  "api/index.js",
                       "use":  "@vercel/node",
                       "config":  {
                                      "includeFiles":  [
                                                           "src/**"
                                                       ]
                                  }
                   }
               ],
    "rewrites":  [
                     {
                         "source":  "/api/(.*)",
                         "destination":  "/api/index.js"
                     }
                 ],
    "crons":  [
                  {
                      "path":  "/api/cron/invoice-cleanup",
                      "schedule":  "0 3 * * *"
                  }
              ]
}
